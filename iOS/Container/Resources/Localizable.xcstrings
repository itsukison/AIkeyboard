    },
    "10キー配列のフリック入力に対応しました。ローマ字と同じように、AIボタンや返信もそのまま使えます。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flick input on a 10-key layout is now supported. Just like romaji, the AI button and replies work the same way."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "现已支持 10 键布局的 flick 输入。与罗马字一样，AI 按钮和回复都可照常使用。"
          }
        }
      }
    },
