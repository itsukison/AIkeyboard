// Copy to Config/Local.xcconfig and fill in values.

// PostHog (container app only). Project token is a publishable key, safe to
// expose in client builds but kept out of git so dev/staging/prod can diverge.
// The // in URLs would be parsed as a comment, so use $() to break it.
POSTHOG_PROJECT_TOKEN =
POSTHOG_HOST = https:/$()/us.i.posthog.com
